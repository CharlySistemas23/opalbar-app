# ─────────────────────────────────────────────
#  OPALBAR APP — Environment Variables Template
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=opalbar-api
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:8081
API_PREFIX=api/v1

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://opalbar:opalbar_secret@localhost:5432/opalbar_db?schema=public

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ──────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── Email (Nodemailer / SMTP) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@opalbar.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=OPALBAR <noreply@opalbar.com>

# ── SMS (Twilio) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

# ── Storage (S3 / Cloudflare R2) ─────────────
STORAGE_PROVIDER=local
S3_BUCKET=opalbar-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ── Push Notifications ───────────────────────
FCM_SERVER_KEY=your_fcm_server_key
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id
APNS_KEY_PATH=./certs/apns.p8
APNS_BUNDLE_ID=com.opalbar.app

# ── Sentry ───────────────────────────────────
SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Rate Limiting ────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_OTP_TTL=300
THROTTLE_OTP_LIMIT=3

# ── Admin ────────────────────────────────────
ADMIN_EMAIL=admin@opalbar.com
ADMIN_PASSWORD=Admin@123456

# ── GDPR ────────────────────────────────────
DATA_RETENTION_DAYS=730
GDPR_DELETION_DELAY_DAYS=30
