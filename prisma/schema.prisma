// ─────────────────────────────────────────────────────────────────────────────
//  OPALBAR APP — Prisma Schema v1.0
//  PostgreSQL · Prisma ORM
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  PENDING_VERIFICATION
  DELETED
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  LOGIN_2FA
  CHANGE_EMAIL
  CHANGE_PHONE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  FULL
}

enum AttendanceStatus {
  REGISTERED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum OfferType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_ITEM
  BUY_ONE_GET_ONE
  COMBO
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  DEPLETED
}

enum PostStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  HIDDEN
  DELETED
}

enum ReactionType {
  LIKE
  LOVE
  FIRE
  CHEER
  SAD
}

enum ReportReason {
  SPAM
  HATE_SPEECH
  VIOLENCE
  MISINFORMATION
  INAPPROPRIATE
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ModerationAction {
  APPROVED
  REJECTED
  HIDDEN
  WARNED
  BANNED_USER
  ESCALATED
}

enum WalletTransactionType {
  EARN
  REDEEM
  EXPIRE
  BONUS
  ADJUSTMENT
  REFUND
}

enum WalletReferenceType {
  EVENT_ATTENDANCE
  OFFER_REDEMPTION
  POST_ENGAGEMENT
  REFERRAL
  WELCOME_BONUS
  ADMIN_ADJUSTMENT
}

enum NotificationType {
  EVENT_REMINDER
  EVENT_NEW
  OFFER_NEW
  OFFER_EXPIRING
  COMMUNITY_REPLY
  COMMUNITY_REACTION
  COMMUNITY_MENTION
  COMMUNITY_FOLLOW
  COMMUNITY_NEW_POST
  VENUE_STORY_NEW
  POST_APPROVED
  POST_REJECTED
  POINTS_EARNED
  POINTS_REDEEMED
  LEVEL_UP
  ACCOUNT_ALERT
  MESSAGE_NEW
  MESSAGE_REQUEST
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  POST_MENTION
  STORY_MENTION
  COMMENT_MENTION
  MENTION_APPROVAL_NEEDED
  SYSTEM
}

enum DmPolicy {
  EVERYONE
  FOLLOWING
  FRIENDS_OF_FRIENDS
  FRIENDS_ONLY
  NONE
}

enum FriendPolicy {
  EVERYONE
  FRIENDS_OF_FRIENDS
  NONE
}

enum MentionPolicy {
  EVERYONE
  FRIENDS_OF_FRIENDS
  FRIENDS_ONLY
  NONE
}

enum MentionTargetType {
  POST
  STORY
  COMMENT
}

enum MentionStatus {
  APPROVED
  PENDING
  REJECTED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum MessageThreadStatus {
  ACCEPTED
  PENDING
  BLOCKED
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContentType {
  IMAGE
  VIDEO
}

enum Gender {
  FEMALE
  MALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum DiscoverySource {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  FRIEND
  WALKED_BY
  GOOGLE
  EVENT
  INFLUENCER
  OTHER
}

enum AdminActionType {
  POINTS_ADJUST
  STATUS_CHANGE
  ROLE_CHANGE
  NOTE_ADDED
  NOTE_UPDATED
  DELETE
  BAN
  UNBAN
  VERIFY
  MESSAGE_SENT
  INTEREST_ADDED
  INTEREST_REMOVED
  PROFILE_UPDATED
}

// ─────────────────────────────────────────────
//  USER & AUTH
// ─────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String?       @unique
  phone         String?       @unique
  passwordHash  String?
  role          UserRole      @default(USER)
  status        UserStatus    @default(PENDING_VERIFICATION)
  isVerified    Boolean       @default(false)
  points        Int           @default(0)
  dmPolicy      DmPolicy      @default(EVERYONE)
  friendPolicy  FriendPolicy  @default(EVERYONE)
  mentionPolicy MentionPolicy @default(EVERYONE)
  isPrivate     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  lastSeenAt    DateTime?

  // Relations
  profile              UserProfile?
  interests            UserInterest[]
  consent              UserConsent?
  sessions             Session[]
  otps                 Otp[]
  events               EventAttendee[]
  offerRedemptions     OfferRedemption[]
  posts                Post[]
  comments             Comment[]
  reactions            Reaction[]
  commentLikes         CommentLike[]
  pushTokens           PushToken[]
  reports              Report[]              @relation("reporter")
  reportedItems        Report[]              @relation("reportedUser")
  moderationLogs       ModerationLog[]       @relation("moderator")
  walletTransactions   WalletTransaction[]
  notifications        Notification[]
  notificationSettings NotificationSettings?
  deletionRequests     DataDeletionRequest[]
  exportRequests       DataExportRequest[]
  loginAttempts        LoginAttempt[]
  reservations         Reservation[]
  supportTickets       SupportTicket[]       @relation("userTickets")
  assignedTickets      SupportTicket[]       @relation("agentTickets")
  supportMessages      SupportMessage[]      @relation("messageSender")
  flagsReviewed        ContentFlag[]         @relation("flagReviewer")
  filterRulesCreated   FilterRule[]          @relation("ruleCreator")
  reviews              Review[]

  // Follows / Messaging / Saved
  followers        Follow[]          @relation("following")
  following        Follow[]          @relation("follower")
  threadsA         MessageThread[]   @relation("threadUserA")
  threadsB         MessageThread[]   @relation("threadUserB")
  messagesSent     Message[]         @relation("messageSender")
  messageReactions MessageReaction[] @relation("messageReactor")
  savedItems       SavedItem[]

  // Friendships (bidirectional)
  friendshipsRequested Friendship[] @relation("friendshipRequester")
  friendshipsReceived  Friendship[] @relation("friendshipAddressee")

  // Mentions (polymorphic across posts/stories)
  mentionsCreated  Mention[] @relation("mentionAuthor")
  mentionsReceived Mention[] @relation("mentionTarget")

  // Stories
  stories    Story[]     @relation("storyAuthor")
  storyViews StoryView[]

  // Admin audit
  adminActionsReceived  AdminActionLog[] @relation("targetUserAdminActions")
  adminActionsPerformed AdminActionLog[] @relation("adminUserAdminActions")

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([role])
}

model UserProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  firstName       String
  lastName        String
  bio             String?          @db.VarChar(500)
  avatarUrl       String?
  coverUrl        String?
  birthDate       DateTime?
  city            String?
  country         String?          @default("MX")
  language        String           @default("es")
  gender          Gender?
  occupation      String?          @db.VarChar(120)
  discoverySource DiscoverySource?
  internalNote    String?          @db.VarChar(2000)
  loyaltyLevel    LoyaltyLevel?    @relation(fields: [loyaltyLevelId], references: [id])
  loyaltyLevelId  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gender])
  @@index([discoverySource])
}

model UserInterest {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category EventCategory @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@index([userId])
}

model UserConsent {
  id               String   @id @default(cuid())
  userId           String   @unique
  termsAccepted    Boolean  @default(false)
  privacyAccepted  Boolean  @default(false)
  marketingConsent Boolean  @default(false)
  analyticsConsent Boolean  @default(false)
  pushConsent      Boolean  @default(true)
  termsVersion     String   @default("1.0")
  privacyVersion   String   @default("1.0")
  consentDate      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  deviceName   String?
  deviceOs     String?
  deviceToken  String? // FCM/APNs push token
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Otp {
  id         String   @id @default(cuid())
  identifier String // email or phone
  code       String
  type       OtpType
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([identifier, type])
  @@index([expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  ipAddress String
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
//  VENUE
// ─────────────────────────────────────────────

model Venue {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?  @db.Text
  address             String
  city                String
  state               String?
  country             String   @default("MX")
  zipCode             String?
  lat                 Decimal? @db.Decimal(10, 8)
  lng                 Decimal? @db.Decimal(11, 8)
  phone               String?
  email               String?
  website             String?
  instagram           String?
  imageUrl            String?
  coverUrl            String?
  isActive            Boolean  @default(true)
  // Reservation config
  openTime            String?  @db.VarChar(5) // "19:00"
  closeTime           String?  @db.VarChar(5) // "02:00"
  reservationCapacity Int?     @default(80)
  reservationsEnabled Boolean  @default(true)
  slotMinutes         Int      @default(30) // duration of each reservation slot
  // Denormalized review stats — avoid AVG over all reviews per detail request.
  // Kept in sync by ReviewsService on create/update/moderate/delete.
  ratingAvg           Decimal  @default(0) @db.Decimal(3, 2) // 0.00-5.00
  ratingCount         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  events       Event[]
  offers       Offer[]
  reservations Reservation[]
  reviews      Review[]

  @@index([slug])
  @@index([city])
}

// ─────────────────────────────────────────────
//  EVENTS
// ─────────────────────────────────────────────

model EventCategory {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  slug      String   @unique
  icon      String?
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  events    Event[]
  interests UserInterest[]

  @@index([slug])
}

model Event {
  id              String      @id @default(cuid())
  title           String
  titleEn         String?
  description     String      @db.Text
  descriptionEn   String?     @db.Text
  imageUrl        String?
  coverUrl        String?
  venueId         String
  categoryId      String
  startDate       DateTime
  endDate         DateTime
  doorsOpenAt     DateTime?
  status          EventStatus @default(DRAFT)
  maxCapacity     Int?
  currentCapacity Int         @default(0)
  price           Decimal?    @db.Decimal(10, 2)
  currency        String      @default("MXN")
  isFree          Boolean     @default(true)
  tags            String[]
  pointsReward    Int         @default(50)
  isHighlighted   Boolean     @default(false)
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  venue        Venue           @relation(fields: [venueId], references: [id])
  category     EventCategory   @relation(fields: [categoryId], references: [id])
  attendees    EventAttendee[]
  media        EventMedia[]
  reservations Reservation[]

  @@index([status])
  @@index([startDate])
  @@index([venueId])
  @@index([categoryId])
  @@index([isHighlighted])
}

model EventMedia {
  id        String      @id @default(cuid())
  eventId   String
  url       String
  type      ContentType @default(IMAGE)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventAttendee {
  id            String           @id @default(cuid())
  userId        String
  eventId       String
  status        AttendanceStatus @default(REGISTERED)
  checkedInAt   DateTime?
  cancelledAt   DateTime?
  pointsAwarded Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([status])
}

// ─────────────────────────────────────────────
//  OFFERS
// ─────────────────────────────────────────────

model Offer {
  id                 String      @id @default(cuid())
  title              String
  titleEn            String?
  description        String      @db.Text
  descriptionEn      String?     @db.Text
  terms              String?     @db.Text
  imageUrl           String?
  venueId            String
  type               OfferType
  status             OfferStatus @default(DRAFT)
  discountValue      Decimal?    @db.Decimal(10, 2)
  minimumPurchase    Decimal?    @db.Decimal(10, 2)
  maxRedemptions     Int?
  currentRedemptions Int         @default(0)
  maxPerUser         Int         @default(1)
  startDate          DateTime
  endDate            DateTime
  daysOfWeek         Int[] // 0=Sun, 1=Mon, ..., 6=Sat
  startTime          String? // HH:MM
  endTime            String? // HH:MM
  isHighlighted      Boolean     @default(false)
  pointsRequired     Int         @default(0)
  categories         String[]
  createdById        String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  venue       Venue             @relation(fields: [venueId], references: [id])
  redemptions OfferRedemption[]

  @@index([status])
  @@index([venueId])
  @@index([startDate, endDate])
  @@index([isHighlighted])
}

model OfferRedemption {
  id        String    @id @default(cuid())
  userId    String
  offerId   String
  code      String    @unique @default(cuid())
  usedAt    DateTime?
  isUsed    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([offerId])
  @@index([code])
}

// ─────────────────────────────────────────────
//  COMMUNITY
// ─────────────────────────────────────────────

model Post {
  id              String     @id @default(cuid())
  userId          String
  content         String     @db.VarChar(2000)
  status          PostStatus @default(PENDING_REVIEW)
  moderationScore Float?
  rejectionReason String?
  imageUrl        String?
  mediaUrls       String[]
  likesCount      Int        @default(0)
  commentsCount   Int        @default(0)
  isPinned        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]
  reports   Report[]   @relation("postReports")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
//  STORIES (ephemeral 24h posts — Instagram style)
// ─────────────────────────────────────────────

enum StoryScope {
  PERSONAL // normal user story
  VENUE // posted by admin, shown as "OPAL BAR PV"
}

model Story {
  id         String     @id @default(cuid())
  userId     String
  scope      StoryScope @default(PERSONAL)
  mediaUrl   String // image URL (base64 for now, Cloudinary later)
  caption    String?    @db.VarChar(500)
  viewsCount Int        @default(0)
  createdAt  DateTime   @default(now())
  expiresAt  DateTime // createdAt + 24h (set at insert time)

  user  User        @relation("storyAuthor", fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([scope, expiresAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

model Comment {
  id         String     @id @default(cuid())
  userId     String
  postId     String
  parentId   String?
  content    String     @db.VarChar(1000)
  status     PostStatus @default(PUBLISHED)
  likesCount Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[]     @relation("CommentReplies")
  reports Report[]      @relation("commentReports")
  likes   CommentLike[]

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String
  targetType   ReportTargetType
  targetId     String
  reason       ReportReason
  description  String?          @db.VarChar(500)
  status       ReportStatus     @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  reporter     User     @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User?    @relation("reportedUser", fields: [targetId], references: [id], onDelete: Cascade, map: "Report_targetId_user_fkey")
  post         Post?    @relation("postReports", fields: [targetId], references: [id], onDelete: Cascade, map: "Report_targetId_post_fkey")
  comment      Comment? @relation("commentReports", fields: [targetId], references: [id], onDelete: Cascade, map: "Report_targetId_comment_fkey")

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([status])
}

model ModerationLog {
  id          String           @id @default(cuid())
  moderatorId String
  targetType  ReportTargetType
  targetId    String
  action      ModerationAction
  reason      String?          @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime         @default(now())

  moderator User @relation("moderator", fields: [moderatorId], references: [id])

  @@index([moderatorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
//  WALLET & LOYALTY
// ─────────────────────────────────────────────

model LoyaltyLevel {
  id        String   @id @default(cuid())
  name      String   @unique
  nameEn    String?
  slug      String   @unique
  minPoints Int
  maxPoints Int?
  color     String // hex color
  icon      String
  benefits  String[] // list of benefit descriptions
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  profiles UserProfile[]

  @@index([minPoints])
}

model WalletTransaction {
  id            String                @id @default(cuid())
  userId        String
  type          WalletTransactionType
  points        Int
  balance       Int // balance after transaction
  description   String
  descriptionEn String?
  referenceId   String?
  referenceType WalletReferenceType?
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
}

// ─────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  titleEn   String?
  body      String
  bodyEn    String?
  data      Json?
  imageUrl  String?
  read      Boolean          @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model NotificationSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  pushEnabled        Boolean  @default(true)
  emailEnabled       Boolean  @default(true)
  eventReminders     Boolean  @default(true)
  newEvents          Boolean  @default(true)
  newOffers          Boolean  @default(true)
  communityReplies   Boolean  @default(true)
  communityReactions Boolean  @default(false)
  pointsUpdates      Boolean  @default(true)
  marketingEmails    Boolean  @default(false)
  weeklyDigest       Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
//  GDPR / DATA REQUESTS
// ─────────────────────────────────────────────

model DataDeletionRequest {
  id           String            @id @default(cuid())
  userId       String
  reason       String?
  scheduledFor DateTime
  processedAt  DateTime?
  status       DataRequestStatus @default(PENDING)
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
}

model DataExportRequest {
  id          String            @id @default(cuid())
  userId      String
  processedAt DateTime?
  status      DataRequestStatus @default(PENDING)
  downloadUrl String?
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
//  RESERVATIONS
// ─────────────────────────────────────────────

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id              String            @id @default(cuid())
  userId          String
  venueId         String
  eventId         String?
  date            DateTime // date only (UTC midnight)
  timeSlot        String // HH:MM
  partySize       Int
  specialRequests String?           @db.VarChar(500)
  status          ReservationStatus @default(PENDING)
  confirmCode     String            @unique @default(cuid())
  confirmedAt     DateTime?
  seatedAt        DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  internalNotes   String?           @db.VarChar(500)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue  @relation(fields: [venueId], references: [id])
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([venueId])
  @@index([eventId])
  @@index([date])
  @@index([status])
  @@index([confirmCode])
}

// ─────────────────────────────────────────────
//  SUPPORT
// ─────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_REVIEW
  WAITING_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  RESERVATION
  ACCOUNT
  BILLING
  TECHNICAL
  OFFER
  COMMUNITY
  OTHER
}

enum MessageSender {
  USER
  AGENT
  SYSTEM
}

model SupportTicket {
  id           String         @id @default(cuid())
  userId       String
  assignedToId String?
  category     TicketCategory @default(OTHER)
  subject      String         @db.VarChar(200)
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user       User             @relation("userTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?            @relation("agentTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   SupportMessage[]

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model SupportMessage {
  id          String        @id @default(cuid())
  ticketId    String
  senderId    String?
  sender      MessageSender
  content     String        @db.VarChar(2000)
  attachments String[]
  isRead      Boolean       @default(false)
  readAt      DateTime?
  createdAt   DateTime      @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUser User?         @relation("messageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

model SupportQuickReply {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.VarChar(1000)
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ─────────────────────────────────────────────
//  CONTENT MONITOR
// ─────────────────────────────────────────────

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlagStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

enum FlagTargetType {
  POST
  COMMENT
  USER_PROFILE
  REVIEW
}

enum FilterRuleAction {
  FLAG
  BLOCK
  AUTO_REJECT
  NOTIFY_ADMIN
}

model ContentFlag {
  id           String         @id @default(cuid())
  targetType   FlagTargetType
  targetId     String
  triggeredBy  String // rule name or "manual"
  severity     FlagSeverity   @default(MEDIUM)
  status       FlagStatus     @default(PENDING)
  matchedText  String?        @db.VarChar(500)
  reviewedById String?
  reviewedAt   DateTime?
  actionTaken  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  reviewedBy User? @relation("flagReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model FilterRule {
  id          String           @id @default(cuid())
  name        String           @unique
  pattern     String // regex or keyword
  isRegex     Boolean          @default(false)
  severity    FlagSeverity     @default(MEDIUM)
  action      FilterRuleAction @default(FLAG)
  isActive    Boolean          @default(true)
  matchCount  Int              @default(0)
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User @relation("ruleCreator", fields: [createdById], references: [id])

  @@index([isActive])
  @@index([severity])
}

// ─────────────────────────────────────────────
//  REVIEWS
// ─────────────────────────────────────────────

enum ReviewStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  HIDDEN
}

model Review {
  id              String       @id @default(cuid())
  userId          String
  venueId         String
  rating          Int // 1–5
  title           String?      @db.VarChar(150)
  body            String?      @db.VarChar(1000)
  pros            String?      @db.VarChar(500)
  cons            String?      @db.VarChar(500)
  visitDate       DateTime?
  status          ReviewStatus @default(PENDING_REVIEW)
  rejectionReason String?
  isVerifiedVisit Boolean      @default(false)
  helpfulCount    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([userId, venueId])
  @@index([venueId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
//  SOCIAL: Follow, Messaging, Saved
// ─────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ─────────────────────────────────────────────
//  FRIENDSHIPS (bidirectional, FB/IG hybrid)
//  · Stored once per pair: requester → addressee
//  · status PENDING until addressee accepts
//  · filteredAt set if request landed in the
//    "Filtradas" tab (low-trust signals)
// ─────────────────────────────────────────────
model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  filteredAt  DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?
  blockedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("friendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("friendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([status])
}

model MessageThread {
  id            String              @id @default(cuid())
  userAId       String
  userBId       String
  lastMessageAt DateTime            @default(now())
  createdAt     DateTime            @default(now())
  status        MessageThreadStatus @default(ACCEPTED)
  requestedById String? // who initiated the conversation (for PENDING threads)

  userA    User      @relation("threadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("threadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
  @@index([status])
}

model Message {
  id               String    @id @default(cuid())
  threadId         String
  senderId         String
  content          String?   @db.Text
  imageUrl         String?
  stickerKey       String?
  audioUrl         String?
  audioDurationSec Int?
  replyToId        String?
  isRead           Boolean   @default(false)
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  thread    MessageThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User              @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo   Message?          @relation("messageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("messageReplies")
  reactions MessageReaction[]

  @@index([threadId, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("messageReactor", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

enum SavedItemType {
  POST
  EVENT
  OFFER
  VENUE
}

model SavedItem {
  id        String        @id @default(cuid())
  userId    String
  type      SavedItemType
  targetId  String
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@index([userId, type])
}

// ─────────────────────────────────────────────
//  APP CONFIG
// ─────────────────────────────────────────────

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  isPublic  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([key])
  @@index([isPublic])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
}

// ─────────────────────────────────────────────
//  ADMIN AUDIT
// ─────────────────────────────────────────────

model AdminActionLog {
  id           String          @id @default(cuid())
  targetUserId String
  adminUserId  String
  action       AdminActionType
  summary      String          @db.VarChar(300)
  before       Json?
  after        Json?
  metadata     Json?
  createdAt    DateTime        @default(now())

  targetUser User @relation("targetUserAdminActions", fields: [targetUserId], references: [id], onDelete: Cascade)
  adminUser  User @relation("adminUserAdminActions", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([action])
}

// ─────────────────────────────────────────────
//  EMAIL MARKETING
// ─────────────────────────────────────────────

enum EmailCampaignTemplate {
  GENERIC
  OFFER
  EVENT
  BIRTHDAY
  WELCOME
  NEWS
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum EmailAudienceType {
  ALL
  NEW_7D
  VIP
  BIRTHDAY_MONTH
  INACTIVE_30D
  CUSTOM
}

model EmailCampaign {
  id           String                @id @default(cuid())
  subject      String                @db.VarChar(200)
  preheader    String?               @db.VarChar(200)
  headline     String                @db.VarChar(160)
  body         String                @db.Text
  ctaLabel     String?               @db.VarChar(60)
  ctaUrl       String?               @db.VarChar(500)
  heroImageUrl String?               @db.VarChar(500)
  template     EmailCampaignTemplate @default(GENERIC)

  // Segmentation stored as JSON — flexible filters
  audienceType   EmailAudienceType @default(ALL)
  audienceFilter Json? // { cities?: string[], interestIds?: string[], loyaltyLevelIds?: string[], minPoints?: number }

  status      EmailCampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?

  recipientCount Int @default(0)
  sentCount      Int @default(0)
  openCount      Int @default(0)
  unsubCount     Int @default(0)
  failCount      Int @default(0)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipients EmailCampaignRecipient[]

  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

model EmailCampaignRecipient {
  id           String    @id @default(cuid())
  campaignId   String
  userId       String
  email        String    @db.VarChar(200)
  unsubToken   String    @unique @default(cuid())
  sentAt       DateTime?
  openedAt     DateTime?
  unsubedAt    DateTime?
  failedReason String?   @db.VarChar(300)
  createdAt    DateTime  @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@index([unsubToken])
}

model MarketingAsset {
  id         String   @id @default(cuid())
  mimeType   String   @db.VarChar(100)
  sizeBytes  Int
  data       Bytes
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────
//  MENTIONS — polymorphic tagging across posts & stories
//  · targetType discriminates POST vs STORY (FK enforced at app layer)
//  · x/y are normalized [0,1] coords for photo tags (null = caption-only)
//  · status APPROVED bypasses approval; PENDING when target user requires it
// ─────────────────────────────────────────────

model Mention {
  id           String            @id @default(cuid())
  targetType   MentionTargetType
  targetId     String
  targetUserId String // who is being mentioned
  authorId     String // who created the mention
  status       MentionStatus     @default(APPROVED)
  x            Float? // 0..1 normalized horizontal coord (photo tag)
  y            Float? // 0..1 normalized vertical coord (photo tag)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  targetUser User @relation("mentionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  author     User @relation("mentionAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, targetUserId])
  @@index([targetUserId, status])
  @@index([targetType, targetId])
  @@index([authorId])
  @@index([status])
}
