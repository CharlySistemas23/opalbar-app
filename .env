# ─────────────────────────────────────────────
#  OPALBAR APP — Local Development Environment
#  DO NOT COMMIT THIS FILE
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=3000
APP_NAME=opalbar-api
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:8081
API_PREFIX=api/v1

DATABASE_URL=postgresql://opalbar:opalbar_secret@localhost:5432/opalbar_db?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

JWT_ACCESS_SECRET=opalbar_access_secret_dev_min_32_chars_ok
JWT_REFRESH_SECRET=opalbar_refresh_secret_dev_min_32_chars_ok
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dev@opalbar.com
SMTP_PASS=dev_smtp_password
EMAIL_FROM=OPALBAR DEV <dev@opalbar.com>

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

STORAGE_PROVIDER=local
S3_BUCKET=opalbar-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dev_access_key
S3_SECRET_ACCESS_KEY=dev_secret_key
S3_ENDPOINT=

FCM_SERVER_KEY=dev_fcm_key
APNS_KEY_ID=dev_apns_key
APNS_TEAM_ID=dev_team_id
APNS_KEY_PATH=./certs/apns.p8
APNS_BUNDLE_ID=com.opalbar.app.dev

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_OTP_TTL=300
THROTTLE_OTP_LIMIT=3

ADMIN_EMAIL=admin@opalbar.com
ADMIN_PASSWORD=Admin@123456

DATA_RETENTION_DAYS=730
GDPR_DELETION_DELAY_DAYS=30
